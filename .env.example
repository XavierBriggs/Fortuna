# FORTUNA operator secrets — copy to .env (gitignored), chmod 600.
# NOTHING in this file may ever be committed, logged, or put in config
# TOML (house rule: secrets via env only). Load before running:
#   set -a; source .env; set +a        (or use direnv)
# sqlx and the CLI read DATABASE_URL; the binaries read the rest.

# --- read by the code TODAY -------------------------------------------

# Postgres (sqlx migrations, repos, audit writer).
DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/fortuna

# Anthropic (the env-key gate IS the cognition feature flag: absent =>
# StubMind, present => AnthropicMind). Recommended first exercise: one
# claude-haiku-4-5 smoke call under a tight CostBudget.
ANTHROPIC_API_KEY=sk-ant-REPLACE-ME

# Slack bot token (xoxb-...) + the five channel IDs (C... ids, NOT
# display names — research-doc mandate). Channels per config/fortuna.toml
# [slack] channels = trading, alerts, review, digest, ops.
FORTUNA_SLACK_BOT_TOKEN=xoxb-REPLACE-ME
FORTUNA_SLACK_CHANNEL_TRADING=C_REPLACE
FORTUNA_SLACK_CHANNEL_ALERTS=C_REPLACE
FORTUNA_SLACK_CHANNEL_REVIEW=C_REPLACE
FORTUNA_SLACK_CHANNEL_DIGEST=C_REPLACE
FORTUNA_SLACK_CHANNEL_OPS=C_REPLACE

# Dead-man monitor ping URL (external service, off-box — the system
# cannot report its own death).
FORTUNA_DEADMAN_URL=https://REPLACE-ME.example/ping/fortuna

# --- Kalshi DEMO run (read TODAY — the demo-flip is MERGED; the daemon boots at
#     venue=kalshi, stage=paper. Demo = MOCK funds; live stages are refused at the
#     boot gate). These are the runtime adapter's own creds.
KALSHI_API_DEMO_KEY_ID=REPLACE-ME
KALSHI_DEMO_PRIVATE_KEY_PATH=/secure/path/kalshi-demo.pem
# NO default — prod vs demo MUST be explicit. Demo: https://demo-api.kalshi.co/trade-api/v2
KALSHI_DEMO_BASE_URL=https://demo-api.kalshi.co/trade-api/v2

# --- Kill switch (I4) — its OWN credential pair, NEVER shared with the runtime.
#     Without these the switch fails closed (exit 4) and only `self-test` runs.
# Kalshi leg (`fortuna-killswitch freeze --venue kalshi`):
FORTUNA_KILLSWITCH_KALSHI_API_KEY_ID=REPLACE-ME
FORTUNA_KILLSWITCH_KALSHI_PRIVATE_KEY_PATH=/secure/path/kalshi-killswitch.pem
FORTUNA_KILLSWITCH_KALSHI_BASE_URL=https://demo-api.kalshi.co/trade-api/v2
# Kinetics perps leg (`fortuna-killswitch flatten-perps`, spec 5.15) — own pair +
# the gate config it re-seals closes through + the cross-the-book slippage budget:
FORTUNA_KILLSWITCH_KINETICS_API_KEY_ID=REPLACE-ME
FORTUNA_KILLSWITCH_KINETICS_PRIVATE_KEY_PATH=/secure/path/kinetics-killswitch.pem
FORTUNA_KILLSWITCH_KINETICS_BASE_URL=https://REPLACE-ME-kinetics-demo/...
FORTUNA_KILLSWITCH_KINETICS_SLIPPAGE_BPS=50
FORTUNA_KILLSWITCH_GATE_CONFIG_PATH=/secure/path/killswitch-gate.toml

# --- I4 REVOCATION (C2): NOT an env var — a CONFIG field. Set
#     [killswitch].revocation_file in config/fortuna.toml to the KILLSWITCH_REVOKED
#     sibling of the killswitch --journal, so after a kill the daemon refuses ALL
#     orders (even across a restart) until you run `fortuna-killswitch
#     clear-revocation --journal <path>` (out-of-band) and re-arm.
