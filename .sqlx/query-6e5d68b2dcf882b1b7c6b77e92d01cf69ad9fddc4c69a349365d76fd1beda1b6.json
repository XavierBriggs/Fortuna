  "query": "SELECT lesson_id, body, provenance, status, review_at, supersedes\n               FROM lessons l\n               WHERE status = 'active'\n                 AND NOT EXISTS (\n                   SELECT 1 FROM lessons l2 WHERE l2.supersedes = l.lesson_id\n                 )\n               ORDER BY created_at, lesson_id",
