  "query": "SELECT signal_id, source, type AS \"kind!\", received_at, content_hash, payload\n               FROM signals\n               WHERE type = ANY($1) AND received_at >= $2\n               ORDER BY received_at DESC, signal_id DESC\n               LIMIT $3",
