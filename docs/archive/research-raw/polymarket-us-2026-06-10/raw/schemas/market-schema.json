  "paths": {
    "/v1/market/id/{id}": {
      "get": {
        "summary": "Get Market By ID",
        "description": "Retrieve a specific market by its ID",
        "operationId": "MarketService_GetMarketsByID",
        "responses": {
          "200": {
            "description": "Market details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/v1GetMarketsByIDResponse"
                }
              }
            }
          },
          "404": {
            "description": "Market not found",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        },
        "parameters": [
          {
            "name": "id",
            "description": "Market ID",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "tags": [
          "Markets"
        ]
      }
    },
    "/v1/market/slug/{slug}": {
      "get": {
        "summary": "Get Market By Slug",
        "description": "Retrieve a specific market by its slug",
        "operationId": "MarketService_GetMarketBySlug",
        "responses": {
          "200": {
            "description": "Market details",
