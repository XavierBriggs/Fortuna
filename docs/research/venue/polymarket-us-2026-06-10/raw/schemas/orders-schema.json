          },
          "transactTime": {
            "type": "string",
            "format": "date-time",
            "description": "Time of the execution"
          },
          "legPrices": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LegPrice"
            },
            "description": "Derived leg prices for multi-leg instrument fills"
          },
          "tradeId": {
            "type": "string",
            "description": "Trade ID if this is a fill"
